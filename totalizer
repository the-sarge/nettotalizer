#!/usr/bin/env bash
# =============================================================================
# totalizer - wrap a command and report network bytes transferred.
# -----------------------------------------------------------------------------
# Usage:
#   totalizer <command> [args...]
#
# Example:
#   totalizer curl -sS -o /dev/null https://example.com/file.tar.gz
#
# Output goes to stderr:
#   [net:     ↓1.2MB ↑45KB]
#
# The wrapped command's stdout, stderr, stdin, and exit code are passed through.
#
# Platforms:
#   macOS uses nettop. It measures the wrapped PID and descendants visible to
#   the sampler.
#   Linux uses bpftrace. It measures the wrapped PID and descendants forked
#   after bpftrace attaches. Only bpftrace runs under sudo; the command does not.
#
# Limitations:
#   These are socket payload bytes, not full interface bytes. Headers,
#   retransmits, and lower-level link overhead are not counted.
#
#   macOS nettop samples at whole-second intervals and descendant discovery is
#   polling-based. Very fast commands or short-lived child processes can finish
#   before the first sample, in which case totalizer reports 0B and warns that
#   no sample was captured.
# =============================================================================

set -u

prog=${0##*/}

usage() {
  cat >&2 <<EOF
Usage: $prog <command> [args...]

Wrap a command and report socket-level network bytes transferred.

Examples:
  $prog curl -sS -o /dev/null https://example.com/file.tar.gz
  $prog git fetch

Output is written to stderr and the wrapped command's exit code is preserved.

Notes:
  macOS uses nettop and samples the wrapped process tree at whole-second
  intervals, so very short commands may finish before a sample is captured.

  Linux uses bpftrace and may ask sudo for the tracer only; the wrapped
  command still runs as the original user.
EOF
  exit 64
}

case "${1:-}" in
  ""|-h|--help) usage ;;
esac

format_bytes() {
  local b=$1

  if [ "$b" -lt 1024 ]; then
    printf '%dB' "$b"
  elif [ "$b" -lt 1048576 ]; then
    awk -v x="$b" 'BEGIN { printf "%.1fKB", x / 1024 }'
  elif [ "$b" -lt 1073741824 ]; then
    awk -v x="$b" 'BEGIN { printf "%.1fMB", x / 1048576 }'
  else
    awk -v x="$b" 'BEGIN { printf "%.2fGB", x / 1073741824 }'
  fi
}

print_summary() {
  local rx=${1:-0}
  local tx=${2:-0}

  printf '\033[39m[\033[2mnet:\033[22m     ↓%s ↑%s]\033[0m\n' \
    "$(format_bytes "$rx")" "$(format_bytes "$tx")" >&2
}

tmpfile() {
  mktemp "${TMPDIR:-/tmp}/${prog}.XXXXXX"
}

run_command_background() {
  # Keep stdin attached when possible. This still is not a full PTY/job-control
  # wrapper, but it avoids breaking simple commands that inspect stdin.
  if [ -t 0 ] && [ -r /dev/tty ]; then
    "$@" </dev/tty &
  else
    "$@" &
  fi

  cmd_pid=$!
}

wait_for_command() {
  local rc

  # A trap can interrupt wait while the child is still alive. Keep waiting until
  # the child is actually gone, then return its real exit status.
  while true; do
    wait "$cmd_pid"
    rc=$?
    kill -0 "$cmd_pid" 2>/dev/null || return "$rc"
  done
}

forward_int() {
  [ -n "${cmd_pid:-}" ] && kill -INT "$cmd_pid" 2>/dev/null
}

forward_term() {
  [ -n "${cmd_pid:-}" ] && kill -TERM "$cmd_pid" 2>/dev/null
}

descendant_pids() {
  local pid=$1
  local child

  printf '%s\n' "$pid"

  for child in $(pgrep -P "$pid" 2>/dev/null || true); do
    descendant_pids "$child"
  done
}

run_macos() {
  if ! command -v nettop >/dev/null 2>&1; then
    echo "$prog: nettop not found; running unmeasured" >&2
    exec "$@"
  fi

  local nt_out sampler_pid cmd_pid exit_code samples rx_tx rx tx

  nt_out=$(tmpfile) || {
    echo "$prog: mktemp failed; running unmeasured" >&2
    exec "$@"
  }

  trap 'rm -f "$nt_out" 2>/dev/null' EXIT

  run_command_background "$@"

  # Use repeated one-shot CSV samples. In infinite logging mode (-L 0), nettop
  # can leave redirected output empty when it is killed after the command exits.
  #
  # nettop flags:
  #   -P       per-process summary, not per-socket rows
  #   -x       raw integer byte counters
  #   -n       avoid DNS/service lookups while sampling
  #   -L 1     CSV logging mode, one flushed sample per invocation
  #   -s 1     portable one-second interval accepted by macOS nettop
  #   -p PID   track one process; repeat for descendants discovered below
  #   -J ...   output only the columns we parse
  (
    local pids pid
    local nettop_args

    while kill -0 "$cmd_pid" 2>/dev/null; do
      pids=$(descendant_pids "$cmd_pid")

      nettop_args=(-n -P -x -L 1 -s 1 -J bytes_in,bytes_out)
      for pid in $pids; do
        nettop_args+=(-p "$pid")
      done

      nettop "${nettop_args[@]}" >>"$nt_out" 2>/dev/null || true

      # Keep the normal sample cadence at one second, but make the pause
      # interruptible so the wrapper does not wait up to a full extra second
      # after the command has exited.
      i=0
      while [ "$i" -lt 10 ] && kill -0 "$cmd_pid" 2>/dev/null; do
        sleep 0.1
        i=$((i + 1))
      done
    done
  ) &
  sampler_pid=$!

  trap forward_int INT
  trap forward_term TERM

  wait_for_command
  exit_code=$?

  wait "$sampler_pid" 2>/dev/null || true

  # Count data rows separately from byte totals so a true zero-transfer command
  # can be distinguished from a command/process tree that finished before nettop
  # captured any sample at all. Because the sampler can track multiple PIDs, keep
  # a max counter per PID and sum those maxima at the end.
  rx_tx=$(awk -F',' '
    # nettop CSV headers look like:
    #   ,bytes_in,bytes_out,
    #
    # Capture column positions from the header instead of assuming fixed indexes.
    /bytes_in|bytes_out/ {
      for (i = 1; i <= NF; i++) {
        if ($i == "bytes_in") in_col = i
        if ($i == "bytes_out") out_col = i
      }
      next
    }

    in_col && out_col && $1 != "" {
      samples++
      key = $1
      if (match(key, /\.[0-9]+$/)) {
        key = substr(key, RSTART + 1)
      }
      seen[key] = 1
      rx = $in_col + 0
      tx = $out_col + 0

      # Counters are cumulative, so the largest value seen is the final total.
      if (rx > max_rx[key]) max_rx[key] = rx
      if (tx > max_tx[key]) max_tx[key] = tx
    }

    END {
      for (key in seen) {
        total_rx += max_rx[key]
        total_tx += max_tx[key]
      }
      printf "%d %d %d\n", samples + 0, total_rx + 0, total_tx + 0
    }
  ' "$nt_out")

  read -r samples rx tx <<<"$rx_tx"

  if [ "${samples:-0}" -eq 0 ]; then
    echo "$prog: no samples captured (process tree finished before nettop's 1s sample tick)" >&2
  fi

  print_summary "${rx:-0}" "${tx:-0}"
  exit "$exit_code"
}


run_linux() {
  if ! command -v bpftrace >/dev/null 2>&1; then
    echo "$prog: bpftrace not found; running unmeasured" >&2
    exec "$@"
  fi

  local bt_out bt_pid cmd_pid exit_code rx tx sudo_cmd

  bt_out=$(tmpfile) || {
    echo "$prog: mktemp failed; running unmeasured" >&2
    exec "$@"
  }

  trap 'rm -f "$bt_out" 2>/dev/null' EXIT

  sudo_cmd=
  if [ "$(id -u)" -ne 0 ]; then
    if ! command -v sudo >/dev/null 2>&1; then
      echo "$prog: bpftrace requires root and sudo is unavailable; running unmeasured" >&2
      exec "$@"
    fi

    # Authenticate before launching the measured command. This avoids counting
    # time spent at a sudo prompt and keeps the wrapped command unprivileged.
    if ! sudo -v; then
      echo "$prog: sudo authentication failed; running unmeasured" >&2
      exec "$@"
    fi

    sudo_cmd=sudo
  fi

  run_command_background "$@"

  local bt_script='
tracepoint:sched:sched_process_fork
/args->parent_pid == $1 || @kids[args->parent_pid]/
{
  @kids[args->child_pid] = 1;
}

kretprobe:tcp_sendmsg /retval > 0 && (pid == $1 || @kids[pid])/
{
  @tx += retval;
}

kretprobe:tcp_recvmsg /retval > 0 && (pid == $1 || @kids[pid])/
{
  @rx += retval;
}

kretprobe:udp_sendmsg /retval > 0 && (pid == $1 || @kids[pid])/
{
  @tx += retval;
}

kretprobe:udp_recvmsg /retval > 0 && (pid == $1 || @kids[pid])/
{
  @rx += retval;
}

kretprobe:udpv6_sendmsg /retval > 0 && (pid == $1 || @kids[pid])/
{
  @tx += retval;
}

kretprobe:udpv6_recvmsg /retval > 0 && (pid == $1 || @kids[pid])/
{
  @rx += retval;
}

END
{
  printf("NETTOTALIZER_RX %lu\n", @rx);
  printf("NETTOTALIZER_TX %lu\n", @tx);
  clear(@kids);
  clear(@rx);
  clear(@tx);
}
'

  # -p ties bpftrace to the command lifetime on versions that support auto-exit.
  # We still send SIGINT after wait so END reliably prints totals.
  $sudo_cmd bpftrace -q -e "$bt_script" -p "$cmd_pid" "$cmd_pid" >"$bt_out" &
  bt_pid=$!

  trap forward_int INT
  trap forward_term TERM

  wait_for_command
  exit_code=$?

  kill -INT "$bt_pid" 2>/dev/null || true
  wait "$bt_pid" 2>/dev/null || true

  rx=$(awk '/^NETTOTALIZER_RX / { value = $2 } END { print value + 0 }' "$bt_out")
  tx=$(awk '/^NETTOTALIZER_TX / { value = $2 } END { print value + 0 }' "$bt_out")

  print_summary "${rx:-0}" "${tx:-0}"
  exit "$exit_code"
}

case "$(uname -s)" in
  Darwin) run_macos "$@" ;;
  Linux)  run_linux "$@" ;;
  *)
    echo "$prog: unsupported platform $(uname -s); running unmeasured" >&2
    exec "$@"
    ;;
esac
