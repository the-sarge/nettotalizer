#!/usr/bin/env bash
# =============================================================================
# totalizer - wrap a command and report network bytes transferred.
# -----------------------------------------------------------------------------
# Usage:
#   totalizer <command> [args...]
#
# Example:
#   totalizer curl -sS -o /dev/null https://example.com/file.tar.gz
#
# Output goes to stderr so stdout remains safe for pipes:
#   total 6.1KB
#   received 5.3KB
#   sent 831B
#
# The wrapped command's stdout, stderr, stdin, and exit code are passed through.
#
# Platforms:
#   macOS uses nettop. It measures the wrapped PID and descendants visible to
#   the sampler.
#   Linux uses bpftrace. It measures the wrapped PID and descendants forked
#   after bpftrace attaches. Only bpftrace runs under sudo; the command does not.
#   FreeBSD, NetBSD, and OpenBSD use a default-interface byte delta estimate.
#
# Limitations:
#   macOS and Linux report socket payload bytes, not full interface bytes.
#   Headers, retransmits, and lower-level link overhead are not counted there.
#   The BSD backend is different: it reports default-interface byte deltas, so
#   unrelated host traffic can be included.
#
#   macOS has no simple, stable, unprivileged event stream for per-process socket
#   byte accounting. The macOS backend therefore polls nettop against the visible
#   process tree. That is good for long-lived children, but short-lived download
#   helpers can still finish between polls. When process samples obviously
#   undercount receive bytes, totalizer may fall back to the default-interface
#   byte delta. That catches tools like Homebrew better, but it is an estimate:
#   it can include unrelated system traffic and counts interface bytes, not just
#   socket payload bytes.
# =============================================================================

set -u

prog=${0##*/}

usage() {
  cat >&2 <<EOF
Usage: $prog <command> [args...]

Wrap a command and report network bytes transferred.

Examples:
  $prog curl -sS -o /dev/null https://example.com/file.tar.gz
  $prog git fetch

Output is written to stderr and the wrapped command's exit code is preserved.
Summary format:
  total 6.1KB
  received 5.3KB
  sent 831B

Notes:
  macOS uses nettop and polls the wrapped process tree, so very short child
  processes may finish between samples. If that misses received bytes, totalizer
  may fall back to default-interface byte deltas, which can include unrelated
  system traffic.

  Linux uses bpftrace and may ask sudo for the tracer only; the wrapped
  command still runs as the original user.

  FreeBSD, NetBSD, and OpenBSD use default-interface byte deltas. This is an
  estimate that can include unrelated traffic from the same host.
EOF
  exit 64
}

case "${1:-}" in
  ""|-h|--help) usage ;;
esac

# Render integer byte counts compactly. Bash has no portable floating point, so
# awk handles the fractional KB/MB/GB cases.
format_bytes() {
  local b=$1

  if [ "$b" -lt 1024 ]; then
    printf '%dB' "$b"
  elif [ "$b" -lt 1048576 ]; then
    awk -v x="$b" 'BEGIN { printf "%.1fKB", x / 1024 }'
  elif [ "$b" -lt 1073741824 ]; then
    awk -v x="$b" 'BEGIN { printf "%.1fMB", x / 1048576 }'
  else
    awk -v x="$b" 'BEGIN { printf "%.2fGB", x / 1073741824 }'
  fi
}

# Keep the summary on stderr because the wrapped command's stdout may be part of
# a pipeline.
print_summary() {
  local rx=${1:-0}
  local tx=${2:-0}
  local total=$((rx + tx))

  printf 'total %s\nreceived %s\nsent %s\n' \
    "$(format_bytes "$total")" "$(format_bytes "$rx")" \
    "$(format_bytes "$tx")" >&2
}

# Use the visible program name in temp paths so traces from `totalizer` and any
# symlink/alias are easy to recognize while debugging.
tmpfile() {
  mktemp "${TMPDIR:-/tmp}/${prog}.XXXXXX"
}

run_command_background_gated() {
  local gate=$1
  shift

  # Used by the measured paths that need a stable root PID before the real
  # command starts. A normal background launch lets fast commands start doing
  # network I/O before the sampler/tracer has attached. Instead, start a tiny
  # bash shim that blocks on a private FIFO. The wrapper starts measurement,
  # writes one byte to the FIFO, and then the shim `exec`s the real command in
  # the same PID.
  # Async bash jobs get /dev/null for stdin unless it is redirected explicitly.
  # Save fd 0 before reading the gate, then restore it for the measured command.
  # If the caller closed stdin, keep it closed and suppress duplicate-fd noise.
  bash -c '
    gate=$1
    shift

    stdin_open=0
    if { exec 9<&0; } 2>/dev/null; then
      stdin_open=1
    fi

    IFS= read -r _ < "$gate"

    if [ "$stdin_open" -eq 1 ]; then
      exec 0<&9 9<&-
    else
      exec 0<&-
    fi

    exec "$@"
  ' \
    "$prog-runner" "$gate" "$@" <&0 &

  cmd_pid=$!
}

wait_for_command() {
  local rc

  # A forwarded signal can interrupt `wait` while the child is still alive. Keep
  # waiting until the child is actually gone so the wrapper returns the wrapped
  # command's real exit status, not the signal-interrupted wait status.
  while true; do
    wait "$cmd_pid"
    rc=$?
    kill -0 "$cmd_pid" 2>/dev/null || return "$rc"
  done
}

forward_int() {
  [ -n "${cmd_pid:-}" ] && kill -INT "$cmd_pid" 2>/dev/null
}

forward_term() {
  [ -n "${cmd_pid:-}" ] && kill -TERM "$cmd_pid" 2>/dev/null
}

measured_command_cleanup() {
  [ -n "${measured_command_gate:-}" ] && rm -f "$measured_command_gate" 2>/dev/null
}

run_command_unmeasured() {
  "$@"
  measured_command_exit_code=$?
  measured_command_measurement_started=0
}

measured_command_noop() {
  :
}

terminate_measured_command_adapter_jobs() {
  local child

  for child in $(jobs -p 2>/dev/null || true); do
    [ -n "${cmd_pid:-}" ] && [ "$child" = "$cmd_pid" ] && continue
    kill -TERM "$child" 2>/dev/null || true
  done
}

reap_measured_command_adapter_jobs() {
  local child

  for child in $(jobs -p 2>/dev/null || true); do
    [ -n "${cmd_pid:-}" ] && [ "$child" = "$cmd_pid" ] && continue
    wait "$child" 2>/dev/null || true
  done
}

stop_measured_command_before_release() {
  local signal=$1

  [ -n "${cmd_pid:-}" ] || return 0

  kill "-$signal" "$cmd_pid" 2>/dev/null || true
  # The gated bash runner can ignore SIGINT before it has exec'd the command.
  # This path runs only before release, so force the shim down and reap it.
  kill -TERM "$cmd_pid" 2>/dev/null || true
  sleep 0.05
  kill -KILL "$cmd_pid" 2>/dev/null || true
  wait "$cmd_pid" 2>/dev/null || true
}

abort_measured_command_before_release() {
  local signal=$1
  local status=$2

  trap - INT
  trap - TERM

  terminate_measured_command_adapter_jobs
  [ -n "${measured_command_adapter_stop:-}" ] &&
    "$measured_command_adapter_stop" 2>/dev/null

  stop_measured_command_before_release "$signal"

  reap_measured_command_adapter_jobs
  measured_command_cleanup
  exit "$status"
}

abort_measured_command_int() {
  abort_measured_command_before_release INT 130
}

abort_measured_command_term() {
  abort_measured_command_before_release TERM 143
}

release_measured_command() {
  if [ -n "${measured_command_gate:-}" ] &&
    [ -p "$measured_command_gate" ] &&
    [ -n "${cmd_pid:-}" ] &&
    kill -0 "$cmd_pid" 2>/dev/null; then
    printf '\n' >"$measured_command_gate"
  fi

  measured_command_cleanup
}

run_measured_command_lifecycle() {
  local adapter_start=$1
  local adapter_await_ready=$2
  local adapter_before_release=$3
  local adapter_after_release=$4
  local adapter_stop=$5
  local adapter_failed_message=$6
  local adapter_timeout_message=$7
  local ready_status exit_code
  shift 7

  measured_command_exit_code=0
  measured_command_measurement_started=0
  measured_command_adapter_stop=$adapter_stop
  measured_command_gate=$(tmpfile) || {
    echo "$prog: mktemp failed; running unmeasured" >&2
    run_command_unmeasured "$@"
    return
  }

  rm -f "$measured_command_gate"
  if ! mkfifo "$measured_command_gate"; then
    echo "$prog: mkfifo failed; running unmeasured" >&2
    measured_command_cleanup
    run_command_unmeasured "$@"
    return
  fi

  run_command_background_gated "$measured_command_gate" "$@"
  trap abort_measured_command_int INT
  trap abort_measured_command_term TERM

  if ! "$adapter_start"; then
    echo "$prog: $adapter_failed_message; running unmeasured" >&2
    "$adapter_stop"
    release_measured_command
    trap forward_int INT
    trap forward_term TERM
    wait_for_command
    measured_command_exit_code=$?
    return
  fi

  measured_command_measurement_started=1
  "$adapter_await_ready"
  ready_status=$?

  if [ "$ready_status" -eq 2 ]; then
    echo "$prog: $adapter_failed_message; running unmeasured" >&2
    measured_command_measurement_started=0
    "$adapter_stop"
    release_measured_command
    trap forward_int INT
    trap forward_term TERM
    wait_for_command
    measured_command_exit_code=$?
    return
  fi

  if [ "$ready_status" -ne 0 ]; then
    echo "$prog: $adapter_timeout_message" >&2
  fi

  "$adapter_before_release"
  release_measured_command
  "$adapter_after_release"
  trap forward_int INT
  trap forward_term TERM

  wait_for_command
  exit_code=$?

  "$adapter_stop"
  measured_command_exit_code=$exit_code
}

descendant_pids() {
  # Recursive pgrep walk of the current process tree. This intentionally reports
  # only descendants that are alive at the instant of the poll; macOS has no
  # unprivileged fork event stream here, so very short-lived children remain the
  # main source of undercounting.
  local pid=$1
  local child

  printf '%s\n' "$pid"

  for child in $(pgrep -P "$pid" 2>/dev/null || true); do
    descendant_pids "$child"
  done
}

default_interface() {
  # route(8) tells us where ordinary internet traffic is likely to leave. VPNs
  # and split routing can make this imperfect, but it is still a useful estimate
  # when process-scoped counters are unavailable or visibly incomplete.
  local iface

  iface=$(route -n get default 2>/dev/null | awk -F': *' '/interface:/ { print $2; exit }')
  if [ -n "$iface" ]; then
    printf '%s\n' "$iface"
    return
  fi

  # Some route(8) variants are more useful for humans than scripts. Fall back to
  # the routing table's interface column when the "route get" output did not
  # expose one in the expected form.
  netstat -rn -f inet 2>/dev/null | awk '
    $1 == "default" || $1 == "0.0.0.0" {
      print $NF
      exit
    }
  '
}

interface_bytes() {
  local iface=$1

  # Read cumulative link-layer byte counters for a single interface. We select
  # the <Link#...> row to avoid duplicate address-family rows for the same
  # interface. These counters include all traffic on that interface, not just the
  # wrapped command, which is why the fallback emits an explicit warning.
  netstat -ibn | awk -v iface="$iface" '
    $1 == iface && $3 ~ /^<Link#/ {
      print $(NF - 4) + 0, $(NF - 1) + 0
      found = 1
      exit
    }
    END {
      if (!found) print "0 0"
    }
  '
}

bsd_interface_bytes() {
  local iface=$1

  # BSD netstat variants all support interface byte counters through the
  # interface display with -b. Parse the Ibytes/Obytes headers instead of fixed
  # columns because the surrounding packet/error columns vary by OS and version.
  netstat -ibn -I "$iface" 2>/dev/null | awk -v iface="$iface" '
    {
      for (i = 1; i <= NF; i++) {
        if ($i == "Ibytes") in_col = i
        if ($i == "Obytes") out_col = i
      }

      if (in_col && out_col && $1 == iface) {
        printf "%d %d\n", $in_col + 0, $out_col + 0
        found = 1
        exit
      }
    }
    END {
      if (!found) exit 1
    }
  '
}

macos_measurement_start() {
  # Use repeated one-shot CSV samples. In infinite logging mode (-L 0), nettop
  # can leave redirected output empty when it is killed after the command exits.
  (
    local nettop_pid

    macos_sampler_cleanup() {
      [ -n "${nettop_pid:-}" ] || return 0

      kill -TERM "$nettop_pid" 2>/dev/null || true
      sleep 0.05
      kill -KILL "$nettop_pid" 2>/dev/null || true
      wait "$nettop_pid" 2>/dev/null || true
      nettop_pid=
    }

    macos_run_nettop_sample() {
      local output=$1
      local pids pid nettop_args nettop_status

      # Rebuild the PID list every poll because package managers and git-like
      # tools often launch short-lived helpers. nettop accepts repeated -p flags,
      # which is the only way to ask for multiple process summaries.
      pids=$(descendant_pids "$cmd_pid")

      nettop_args=(-n -P -x -L 1 -s 1 -J bytes_in,bytes_out)
      for pid in $pids; do
        nettop_args+=(-p "$pid")
      done

      nettop "${nettop_args[@]}" >>"$output" 2>/dev/null &
      nettop_pid=$!
      wait "$nettop_pid"
      nettop_status=$?
      nettop_pid=

      return "$nettop_status"
    }

    trap 'macos_sampler_cleanup; exit 0' HUP INT TERM

    rm -f "$sampler_status" 2>/dev/null || true
    rm -f "$sampler_released" 2>/dev/null || true
    if macos_run_nettop_sample /dev/null; then
      printf 'ready\n' >"$sampler_status"
    else
      printf 'failed\n' >"$sampler_status"
      exit 0
    fi

    while kill -0 "$cmd_pid" 2>/dev/null && [ ! -e "$sampler_released" ]; do
      sleep 0.01
    done

    while kill -0 "$cmd_pid" 2>/dev/null; do
      macos_run_nettop_sample "$nt_out" || true

      # nettop -L 1 returns a current snapshot immediately. Poll quickly so
      # short-lived downloader children, such as Homebrew's fetch helpers, are
      # less likely to appear and disappear between samples.
      kill -0 "$cmd_pid" 2>/dev/null && sleep 0.1
    done
  ) &
  sampler_pid=$!
}

macos_measurement_before_release() {
  # Capture the fallback baseline after the sampler is ready, immediately before
  # the real command is released. This excludes unrelated traffic that happened
  # while the command was still gated.
  iface=
  iface_before=
  iface_rx_before=0
  iface_tx_before=0

  iface=$(default_interface)
  if [ -n "$iface" ]; then
    iface_before=$(interface_bytes "$iface")
    if [ -n "$iface_before" ]; then
      read -r iface_rx_before iface_tx_before <<<"$iface_before"
    else
      iface=
    fi
  fi
}

macos_measurement_after_release() {
  : >"$sampler_released" || true
}

macos_measurement_await_ready() {
  local i status

  for ((i = 0; i < 600; i++)); do
    if [ -s "$sampler_status" ]; then
      status=$(cat "$sampler_status")
      [ "$status" = ready ] && return 0
      return 2
    fi

    kill -0 "$sampler_pid" 2>/dev/null || return 2
    sleep 0.05
  done

  return 1
}

macos_measurement_stop() {
  [ -n "${sampler_pid:-}" ] || return 0
  if [ -n "${cmd_pid:-}" ] && kill -0 "$cmd_pid" 2>/dev/null; then
    kill -TERM "$sampler_pid" 2>/dev/null || true
  fi
  wait "$sampler_pid" 2>/dev/null || true
}

run_macos() {
  if ! command -v nettop >/dev/null 2>&1; then
    echo "$prog: nettop not found; running unmeasured" >&2
    exec "$@"
  fi

  local nt_out sampler_status sampler_released sampler_pid cmd_pid exit_code samples rx_tx rx tx
  local iface iface_before iface_after iface_rx_before iface_tx_before
  local iface_rx_after iface_tx_after iface_rx_delta iface_tx_delta fallback_used
  local measured_command_gate measured_command_exit_code
  local measured_command_measurement_started measured_command_adapter_stop

  # macOS strategy, in plain English:
  #
  #   1. Create a temp CSV file for nettop snapshots.
  #   2. Let the measured command lifecycle launch a gated bash shim.
  #   3. Start the sampler against the shim PID, then let the lifecycle release
  #      the gate.
  #   4. The shim execs the real command, preserving that PID as the root.
  #   5. Every poll, discover currently-live descendants and ask nettop for a
  #      one-shot CSV snapshot for every PID we know about.
  #   6. After the command exits, sum each PID's maximum observed counters.
  #   7. If nettop clearly missed receive traffic, optionally replace the result
  #      with the default-interface byte delta and warn that it is an estimate.
  #
  # This is intentionally conservative in what it claims. The process-tree total
  # is scoped but sampled. The interface fallback is complete for the interface
  # interval but not scoped to the command. Neither is a perfect macOS answer.

  nt_out=$(tmpfile) || {
    echo "$prog: mktemp failed; running unmeasured" >&2
    exec "$@"
  }
  sampler_status=$nt_out.status
  sampler_released=$nt_out.released

  trap 'rm -f "$nt_out" "$sampler_status" "$sampler_released" 2>/dev/null; measured_command_cleanup' EXIT

  run_measured_command_lifecycle \
    macos_measurement_start \
    macos_measurement_await_ready \
    macos_measurement_before_release \
    macos_measurement_after_release \
    macos_measurement_stop \
    "macOS sampler exited before command start" \
    "macOS sampler did not become ready before command start; measurement may undercount" \
    "$@"
  exit_code=$measured_command_exit_code

  if [ "$measured_command_measurement_started" -ne 1 ]; then
    exit "$exit_code"
  fi

  # Parse the accumulated CSV snapshots.
  #
  # Important details:
  #   * nettop emits a header for each -L 1 invocation; discover columns from
  #     headers instead of assuming a fixed layout.
  #   * Data rows are keyed by "process-name.PID". Strip the trailing ".PID" and
  #     key by PID so the same process is not double-counted when the gated bash
  #     shim execs into the real command and the displayed name changes.
  #   * Counters are cumulative per process, so the largest observed rx/tx value
  #     for each PID is that PID's best final total.
  #   * `samples` counts data rows. A zero sample count is different from a
  #     sampled process with true 0B traffic, so we warn only in the former case.
  rx_tx=$(awk -F',' '
    # nettop CSV headers look like:
    #   ,bytes_in,bytes_out,
    #
    # Capture column positions from the header instead of assuming fixed indexes.
    /bytes_in|bytes_out/ {
      for (i = 1; i <= NF; i++) {
        if ($i == "bytes_in") in_col = i
        if ($i == "bytes_out") out_col = i
      }
      next
    }

    in_col && out_col && $1 != "" {
      samples++
      key = $1
      if (match(key, /\.[0-9]+$/)) {
        key = substr(key, RSTART + 1)
      }
      seen[key] = 1
      rx = $in_col + 0
      tx = $out_col + 0

      # Counters are cumulative, so the largest value seen is the final total.
      if (rx > max_rx[key]) max_rx[key] = rx
      if (tx > max_tx[key]) max_tx[key] = tx
    }

    END {
      for (key in seen) {
        total_rx += max_rx[key]
        total_tx += max_tx[key]
      }
      printf "%d %d %d\n", samples + 0, total_rx + 0, total_tx + 0
    }
  ' "$nt_out")

  read -r samples rx tx <<<"$rx_tx"

  # Fallback estimate:
  #
  # If the process-scoped sampler reports little or no receive traffic while the
  # default interface advanced materially, prefer the interface delta. This is
  # what makes fast Homebrew downloads produce a useful number instead of 0B.
  #
  # Thresholds are intentionally blunt:
  #   * require >64KB interface RX so ordinary background chatter does not flip
  #     tiny commands into fallback mode;
  #   * require the interface delta to beat process RX by >64KB; and
  #   * if process RX is nonzero, require the interface delta to be >2x process
  #     RX so we do not replace good process data for small differences.
  #
  # When this triggers, print an explicit warning because the value is no longer
  # scoped only to the process tree and includes link-layer bytes.
  fallback_used=0
  if [ -n "${iface:-}" ]; then
    iface_after=$(interface_bytes "$iface")
    read -r iface_rx_after iface_tx_after <<<"$iface_after"

    iface_rx_delta=$((iface_rx_after - ${iface_rx_before:-0}))
    iface_tx_delta=$((iface_tx_after - ${iface_tx_before:-0}))
    [ "$iface_rx_delta" -lt 0 ] && iface_rx_delta=0
    [ "$iface_tx_delta" -lt 0 ] && iface_tx_delta=0

    if [ "$iface_rx_delta" -gt 65536 ] &&
      [ "$iface_rx_delta" -gt $((${rx:-0} + 65536)) ] &&
      { [ "${rx:-0}" -eq 0 ] || [ "$iface_rx_delta" -gt $((${rx:-0} * 2)) ]; }; then
      rx=$iface_rx_delta
      tx=$iface_tx_delta
      fallback_used=1
    fi
  fi

  if [ "$fallback_used" -eq 1 ]; then
    echo "$prog: process samples undercounted received bytes; using $iface interface delta" >&2
  elif [ "${samples:-0}" -eq 0 ]; then
    echo "$prog: no samples captured (process tree finished between nettop polls)" >&2
  fi

  print_summary "${rx:-0}" "${tx:-0}"
  exit "$exit_code"
}

linux_measurement_start() {
  # -p ties bpftrace to the command lifetime on versions that support auto-exit.
  # We still send SIGINT after wait so END reliably prints totals.
  $sudo_cmd bpftrace -q -e "$bt_script" -p "$cmd_pid" "$cmd_pid" >"$bt_out" &
  bt_pid=$!
}

linux_measurement_await_ready() {
  local i

  # Older bpftrace builds can take several seconds to compile and attach the
  # first time they run on a fresh host. Wait long enough to keep fast commands
  # gated until the tracer has really started.
  for ((i = 0; i < 600; i++)); do
    if grep -q '^NETTOTALIZER_READY$' "$bt_out" 2>/dev/null; then
      return 0
    fi

    kill -0 "$bt_pid" 2>/dev/null || return 2
    sleep 0.05
  done

  return 1
}

linux_measurement_stop() {
  [ -n "${bt_pid:-}" ] || return 0
  kill -INT "$bt_pid" 2>/dev/null || true
  wait "$bt_pid" 2>/dev/null || true
}

run_linux() {
  if ! command -v bpftrace >/dev/null 2>&1; then
    echo "$prog: bpftrace not found; running unmeasured" >&2
    exec "$@"
  fi

  local bt_out bt_pid cmd_pid exit_code rx tx sudo_cmd
  local measured_command_gate measured_command_exit_code
  local measured_command_measurement_started measured_command_adapter_stop

  # Linux strategy:
  #
  #   * bpftrace gives us event-style accounting rather than polling. That is
  #     why Linux can follow descendants more accurately than macOS here.
  #   * The wrapped command still runs as the invoking user. Only bpftrace is
  #     run through sudo when root privileges are needed.
  #   * We hook fork events to maintain a descendant set, then sum positive
  #     return values from tcp/udp send/recv kernel paths for the root PID or
  #     any tracked child.
  #   * This counts socket payload bytes returned by those kernel functions. It
  #     still does not count raw sockets, AF_PACKET, or other nonstandard paths.

  bt_out=$(tmpfile) || {
    echo "$prog: mktemp failed; running unmeasured" >&2
    exec "$@"
  }

  sudo_cmd=
  if [ "$(id -u)" -ne 0 ]; then
    if ! command -v sudo >/dev/null 2>&1; then
      echo "$prog: bpftrace requires root and sudo is unavailable; running unmeasured" >&2
      exec "$@"
    fi

    # Authenticate before launching the measured command. This avoids counting
    # time spent at a sudo prompt and keeps the wrapped command unprivileged.
    if ! sudo -v; then
      echo "$prog: sudo authentication failed; running unmeasured" >&2
      exec "$@"
    fi

    sudo_cmd=sudo
  fi

  # The bpftrace script uses positional argument $1 for the root PID. @kids is
  # populated from sched_process_fork so grandchildren are included after their
  # parents have been marked. kretprobes are used instead of entry probes because
  # the positive return value is the number of bytes actually transferred.
  local bt_script='
BEGIN
{
  printf("NETTOTALIZER_READY\n");
}

tracepoint:sched:sched_process_fork
/args->parent_pid == (int32)$1 || @kids[args->parent_pid]/
{
  @kids[args->child_pid] = 1;
}

kretprobe:tcp_sendmsg /retval > 0 && retval <= 2147483647 && (pid == $1 || @kids[pid])/
{
  @tx += retval;
}

kretprobe:tcp_recvmsg /retval > 0 && retval <= 2147483647 && (pid == $1 || @kids[pid])/
{
  @rx += retval;
}

kretprobe:udp_sendmsg /retval > 0 && retval <= 2147483647 && (pid == $1 || @kids[pid])/
{
  @tx += retval;
}

kretprobe:udp_recvmsg /retval > 0 && retval <= 2147483647 && (pid == $1 || @kids[pid])/
{
  @rx += retval;
}

kretprobe:udpv6_sendmsg /retval > 0 && retval <= 2147483647 && (pid == $1 || @kids[pid])/
{
  @tx += retval;
}

kretprobe:udpv6_recvmsg /retval > 0 && retval <= 2147483647 && (pid == $1 || @kids[pid])/
{
  @rx += retval;
}

END
{
  printf("NETTOTALIZER_RX %lu\n", @rx);
  printf("NETTOTALIZER_TX %lu\n", @tx);
  clear(@kids);
  clear(@rx);
  clear(@tx);
}
'

  trap 'rm -f "$bt_out" 2>/dev/null; measured_command_cleanup' EXIT

  run_measured_command_lifecycle \
    linux_measurement_start \
    linux_measurement_await_ready \
    measured_command_noop \
    measured_command_noop \
    linux_measurement_stop \
    "bpftrace exited before command start" \
    "bpftrace did not become ready before command start; measurement may undercount" \
    "$@"
  exit_code=$measured_command_exit_code

  if [ "$measured_command_measurement_started" -ne 1 ]; then
    exit "$exit_code"
  fi

  # Use the last printed values in case bpftrace emits multiple lines around
  # shutdown. Missing values intentionally collapse to 0 so measurement failure
  # does not change the wrapped command's exit status.
  rx=$(awk '/^NETTOTALIZER_RX / { value = $2 } END { print value + 0 }' "$bt_out")
  tx=$(awk '/^NETTOTALIZER_TX / { value = $2 } END { print value + 0 }' "$bt_out")

  print_summary "${rx:-0}" "${tx:-0}"
  exit "$exit_code"
}

run_bsd() {
  if ! command -v route >/dev/null 2>&1 || ! command -v netstat >/dev/null 2>&1; then
    echo "$prog: route/netstat not found; running unmeasured" >&2
    exec "$@"
  fi

  local iface iface_before iface_after rx_before tx_before rx_after tx_after
  local rx tx exit_code

  iface=$(default_interface)
  if [ -z "$iface" ]; then
    echo "$prog: default route interface not found; running unmeasured" >&2
    exec "$@"
  fi

  iface_before=$(bsd_interface_bytes "$iface")
  if [ -z "$iface_before" ]; then
    echo "$prog: could not read $iface byte counters; running unmeasured" >&2
    exec "$@"
  fi
  read -r rx_before tx_before <<<"$iface_before"

  "$@"
  exit_code=$?

  iface_after=$(bsd_interface_bytes "$iface")
  if [ -z "$iface_after" ]; then
    echo "$prog: could not read $iface byte counters after command" >&2
    print_summary 0 0
    exit "$exit_code"
  fi
  read -r rx_after tx_after <<<"$iface_after"

  rx=$((rx_after - rx_before))
  tx=$((tx_after - tx_before))
  [ "$rx" -lt 0 ] && rx=0
  [ "$tx" -lt 0 ] && tx=0

  echo "$prog: BSD backend uses $iface interface delta estimate; includes unrelated traffic" >&2
  print_summary "$rx" "$tx"
  exit "$exit_code"
}

case "$(uname -s)" in
  Darwin)                    run_macos "$@" ;;
  Linux)                     run_linux "$@" ;;
  FreeBSD|NetBSD|OpenBSD)    run_bsd "$@" ;;
  *)
    echo "$prog: unsupported platform $(uname -s); running unmeasured" >&2
    exec "$@"
    ;;
esac
